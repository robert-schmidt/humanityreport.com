*{margin:0;padding:0;box-sizing:border-box} body{background:#050505;min-height:100vh;font-family:'Segoe UI',system-ui,sans-serif;color:#d0d0d0;line-height:1.7} .hero{text-align:center;padding:50px 20px 30px;border-bottom:1px solid #1a1a1a;background:linear-gradient(180deg,#0a0a0a 0%,#050505 100%)} .site-title{font-size:0.85rem;letter-spacing:4px;text-transform:uppercase;color:#909090;margin-bottom:20px} .site-title a{color:#909090;text-decoration:none;transition:color 0.3s} .site-title a:hover{color:#b0b0b0} h1{font-size:2.4rem;font-weight:200;letter-spacing:3px;margin-bottom:15px;color:#fff} .hero p{color:#909090;font-size:1rem;max-width:750px;margin:0 auto} .main-container{max-width:1400px;margin:0 auto;padding:25px} .chart-section{background:linear-gradient(135deg,#0a0a0a 0%,#0d0d0d 100%);border-radius:10px;padding:30px;margin-bottom:30px;border:1px solid #1a1a1a;box-shadow:0 4px 30px rgba(0,0,0,0.5)} .display-row{display:flex;justify-content:center;align-items:baseline;gap:40px;margin-bottom:20px;flex-wrap:wrap} .year-display{font-size:3.2rem;font-weight:200;color:#fff;font-family:'Courier New',monospace} .pop-display{font-size:1.5rem;color:#a0a0a0} .era-display{font-size:0.85rem;color:#858585;text-transform:uppercase;letter-spacing:2px} .chart-container{position:relative;height:450px;cursor:grab;overflow:hidden} .chart-container:active,.chart-container.dragging{cursor:grabbing} .chart-bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;opacity:0.35;pointer-events:none} .chart-canvas{position:relative;z-index:1;width:100%;height:100%} .question-mark{position:absolute;right:6%;top:8%;z-index:2;font-size:9rem;font-weight:200;color:rgba(255,70,70,0.5);opacity:0;transition:opacity 1.2s ease-in;pointer-events:none;text-shadow:0 0 50px rgba(255,70,70,0.3);font-family:Georgia,serif} .y-axis-label{position:absolute;left:10px;top:50%;transform:rotate(-90deg) translateX(-50%);transform-origin:left center;font-size:0.7rem;color:#858585;letter-spacing:1px} .timeline-hint{text-align:center;color:#808080;font-size:0.75rem;margin-top:10px;font-style:italic} .controls{text-align:center;margin-top:20px} button{padding:12px 50px;font-size:0.9rem;background:transparent;border:1px solid #333;color:#aaa;cursor:pointer;transition:all 0.3s;letter-spacing:2px;text-transform:uppercase} button:hover{background:#fff;color:#000;border-color:#fff} .marker-legend{display:flex;flex-wrap:wrap;gap:15px;justify-content:center;margin-top:15px;padding-top:15px;border-top:1px solid #1a1a1a} .marker-item{display:flex;align-items:center;gap:6px;font-size:0.7rem;color:#909090} .marker-dot{width:8px;height:8px;border-radius:50%} .marker-dot.red{background:rgba(200,80,80,0.8)} .marker-dot.blue{background:rgba(80,120,200,0.8)} .marker-dot.green{background:rgba(80,200,120,0.8)} .marker-dot.yellow{background:rgba(200,180,80,0.8)} .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:15px;margin-top:25px} .stat-box{text-align:center;padding:22px 10px;background:#080808;border:1px solid #151515;border-radius:6px} .stat-value{font-size:1.6rem;color:#fff;font-weight:200} .stat-label{font-size:0.65rem;color:#909090;text-transform:uppercase;letter-spacing:1px;margin-top:6px} .perspective-box{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:20px;padding:25px;background:linear-gradient(135deg,#0a0808 0%,#0d0a0a 100%);border:1px solid #2a1515;border-radius:8px} .perspective-stat{text-align:center;padding:10px} .perspective-value{display:block;font-size:2rem;font-weight:200;color:#cc8888;margin-bottom:8px} .perspective-desc{font-size:0.8rem;color:#a0a0a0;line-height:1.5} .perspective-desc strong{color:#aa7777} .section-title{font-size:1.3rem;font-weight:300;color:#fff;margin:55px 0 25px;padding-bottom:12px;border-bottom:1px solid #1a1a1a;letter-spacing:2px;text-transform:uppercase} .info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:20px} .info-card{background:linear-gradient(135deg,#0a0a0a 0%,#0d0d0d 100%);border:1px solid #1a1a1a;border-radius:8px;padding:25px} .info-card h3{font-size:0.75rem;text-transform:uppercase;letter-spacing:2px;color:#909090;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid #1a1a1a} .info-card.warning{border-color:#2a1515;background:linear-gradient(135deg,#0a0808 0%,#0d0a0a 100%)} .info-card.warning h3{color:#cc7777;border-color:#2a1515} .info-card.ai-section{border-color:#152a20;background:linear-gradient(135deg,#080a08 0%,#0a0d0a 100%)} .info-card.ai-section h3{color:#77bb88;border-color:#152a20} .checkpoint{display:flex;align-items:flex-start;margin-bottom:14px;padding-bottom:14px;border-bottom:1px solid #111} .checkpoint:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0} .checkpoint-year{min-width:95px;font-family:'Courier New',monospace;color:#ccc;font-size:0.8rem} .checkpoint-pop{min-width:75px;color:#909090;font-size:0.8rem} .checkpoint-event{color:#b0b0b0;font-size:0.8rem} .factor-item,.threat-item,.ai-item{margin-bottom:14px;padding-left:15px;border-left:2px solid #222;transition:border-color 0.3s} .factor-item:hover{border-left-color:#666} .threat-item{border-left-color:#331a1a} .threat-item:hover{border-left-color:#884444} .ai-item{border-left-color:#1a331a} .ai-item:hover{border-left-color:#448844} .factor-title{color:#ddd;font-size:0.85rem;margin-bottom:4px} .factor-desc{color:#a0a0a0;font-size:0.8rem} .threat-title{color:#dd9999;font-size:0.85rem;margin-bottom:4px} .threat-desc{color:#a0a0a0;font-size:0.8rem} .ai-title{color:#99cc99;font-size:0.85rem;margin-bottom:4px} .ai-desc{color:#a0a0a0;font-size:0.8rem} .robot-section{background:linear-gradient(135deg,#080a08 0%,#0a0d0a 100%);border:1px solid #1a2a1a;border-radius:10px;padding:40px;margin-top:45px} .robot-section h2{font-size:1rem;font-weight:400;color:#77aa88;margin-bottom:25px;text-transform:uppercase;letter-spacing:3px} .robot-section p{color:#b0b0b0;margin-bottom:18px;font-size:0.95rem} .robot-section p:last-child{margin-bottom:0} .robot-section em{color:#99ccaa;font-style:normal} .robot-section strong{color:#ddd;font-weight:400} .ai-tabs{display:flex;gap:10px;margin-bottom:25px;border-bottom:1px solid #1a2a1a;padding-bottom:15px;flex-wrap:wrap} .ai-tab{padding:8px 20px;background:transparent;border:1px solid #1a2a1a;color:#8899aa;cursor:pointer;font-size:0.8rem;letter-spacing:1px;text-transform:uppercase;transition:all 0.3s;border-radius:4px} .ai-tab:hover{border-color:#2a3a2a;color:#77aa88} .ai-tab.active{background:#1a2a1a;border-color:#2a3a2a;color:#77aa88} .ai-content{min-height:200px} .ai-content p{color:#b0b0b0;margin-bottom:18px;font-size:0.95rem} .ai-content p:last-child{margin-bottom:0} .ai-content em{color:#99ccaa;font-style:normal} .ai-content strong{color:#ddd;font-weight:400} .version-nav{display:flex;align-items:center;justify-content:center;gap:20px;margin-top:30px;padding-top:20px;border-top:1px solid #1a2a1a} .version-arrow{background:transparent;border:1px solid #1a2a1a;color:#8899aa;width:36px;height:36px;cursor:pointer;font-size:1rem;transition:all 0.3s;border-radius:4px;padding:0;display:flex;align-items:center;justify-content:center} .version-arrow:hover:not(:disabled){border-color:#2a3a2a;color:#77aa88} .version-arrow:disabled{opacity:0.3;cursor:not-allowed} .version-info{font-size:0.75rem;color:#8899aa;letter-spacing:1px;min-width:150px;text-align:center} .prompt-subtitle{background:rgba(30,50,35,0.3);border:1px solid #1a2a1a;border-radius:6px;padding:15px 20px;margin-bottom:25px;font-size:0.75rem;color:#99aabb;line-height:1.6;font-style:italic} .prompt-subtitle strong{color:#77aa88;font-weight:400} .prompt-subtitle a{color:#88bb88;text-decoration:none} .prompt-subtitle a:hover{color:#aaddaa;text-decoration:underline} .malthus-section{background:linear-gradient(135deg,#0d0a08 0%,#100d0a 100%);border:1px solid #2a2015;border-radius:10px;padding:40px;margin-top:40px;margin-bottom:10px} .malthus-header{text-align:center;margin-bottom:30px} .malthus-header h2{font-size:1.3rem;font-weight:300;color:#c9a868;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px} .malthus-subtitle{font-size:0.9rem;color:#bbaa88;font-style:italic} .malthus-grid{display:grid;grid-template-columns:1fr 1.5fr;gap:30px;align-items:start} .malthus-card{background:rgba(0,0,0,0.3);border:1px solid #2a2015;border-radius:8px;padding:25px} .malthus-quote{font-size:1.1rem;color:#b89858;line-height:1.6;font-style:italic;margin-bottom:15px} .malthus-source{font-size:0.75rem;color:#bbaa88;text-align:right} .malthus-source em{font-style:italic} .malthus-content p{color:#b0b0b0;font-size:0.9rem;margin-bottom:15px;line-height:1.6} .malthus-content p:last-child{margin-bottom:0} .malthus-content strong{color:#c9a868;font-weight:400} @media (max-width:900px){.malthus-grid{grid-template-columns:1fr} } .energy-slaves-svg{display:block;width:100%;height:auto;max-height:320px;margin:0 auto 20px;background:rgba(0,0,0,0.25);border:1px solid #1a1a1a;border-radius:8px;padding:10px} .polycrisis-section{background:linear-gradient(135deg,#0a0a0d 0%,#0d0a10 100%);border:1px solid #1f1a2a;border-radius:10px;padding:40px 35px;margin-top:40px;margin-bottom:10px} .polycrisis-header{text-align:center;margin-bottom:35px} .polycrisis-header h2{font-size:1.3rem;font-weight:300;color:#b39ad8;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px} .polycrisis-subtitle{font-size:0.9rem;color:#9a8eb0;font-style:italic} .polycrisis-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px} .loop-card{background:rgba(0,0,0,0.35);border:1px solid #1f1a2a;border-left:3px solid #4a3d6b;border-radius:6px;padding:22px;position:relative;transition:border-left-color 0.3s,background 0.3s} .loop-card:hover{border-left-color:#7861f3;background:rgba(0,0,0,0.45)} .loop-num{position:absolute;top:14px;right:18px;font-size:0.75rem;color:#4a3d6b;letter-spacing:2px;font-family:Georgia,serif} .loop-title{color:#b39ad8;font-size:0.95rem;font-weight:500;margin-bottom:10px;letter-spacing:0.5px} .loop-chain{color:#8e7eb0;font-size:0.78rem;font-style:italic;margin-bottom:12px;line-height:1.55;padding-bottom:12px;border-bottom:1px dashed #2a2235} .loop-desc{color:#b0b0b0;font-size:0.85rem;line-height:1.6} .polycrisis-footer{text-align:center;color:#b39ad8;font-size:0.95rem;font-style:italic;margin-top:35px;padding-top:25px;border-top:1px solid #1f1a2a;line-height:1.6} @media (max-width:900px){.polycrisis-grid{grid-template-columns:1fr} .polycrisis-section{padding:30px 20px} } .footnote{text-align:center;padding:35px 20px;color:#909090;font-size:0.75rem;border-top:1px solid #111;margin-top:50px} .footnote a{color:#7861f3;text-decoration:none;transition:color 0.3s} .footnote a:hover{color:#9d8af7} .references{max-width:1200px;margin:0 auto;padding:40px 25px 60px} .references h2{font-size:1.2rem;font-weight:300;color:#a0a0a0;margin-bottom:30px;text-transform:uppercase;letter-spacing:2px;text-align:center} .ref-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:30px} .ref-category{background:#080808;border:1px solid #151515;border-radius:8px;padding:20px} .ref-category h4{font-size:0.7rem;text-transform:uppercase;letter-spacing:2px;color:#909090;margin-bottom:15px;padding-bottom:10px;border-bottom:1px solid #1a1a1a} .ref-category ol{list-style:none;padding:0;margin:0} .ref-category li{font-size:0.75rem;color:#909090;margin-bottom:12px;padding-left:0;line-height:1.5} .ref-category li:last-child{margin-bottom:0} .ref-category li em{color:#b0b0b0;font-style:italic} .ref-category li a{color:#6b5ce7;text-decoration:none;transition:color 0.3s} .ref-category li a:hover{color:#8b7cf7} .scroll-reveal{opacity:0;transform:translateY(28px);transition:opacity 0.75s ease-out,transform 0.75s ease-out;will-change:opacity,transform} .scroll-reveal.is-visible{opacity:1;transform:translateY(0)} @media (prefers-reduced-motion:reduce){.scroll-reveal{opacity:1;transform:none;transition:none} } .manifesto-teaser{background:linear-gradient(135deg,#0d0a08 0%,#100d0a 100%);border:1px solid #2a2015;border-left:3px solid #c9a868;border-radius:8px;padding:24px 28px;margin-bottom:25px;position:relative} .manifesto-teaser-tag{position:absolute;top:-10px;left:22px;background:#050505;padding:0 10px;font-size:0.65rem;color:#c9a868;text-transform:uppercase;letter-spacing:3px} .manifesto-teaser-lede{color:#c9a868;font-size:1.05rem;font-weight:400;line-height:1.5;margin-bottom:10px;font-family:Georgia,serif;font-style:italic} .manifesto-teaser-body{color:#b0b0b0;font-size:0.88rem;line-height:1.65;margin-bottom:14px} .manifesto-teaser-cta{display:inline-block;color:#c9a868;font-size:0.8rem;text-decoration:none;letter-spacing:1.5px;text-transform:uppercase;border-bottom:1px solid transparent;transition:border-color 0.3s,color 0.3s} .manifesto-teaser-cta:hover{color:#e0c084;border-bottom-color:#e0c084} .manifesto-page{max-width:900px} .manifesto-preamble{background:linear-gradient(135deg,#0a0a0a 0%,#0d0d0d 100%);border:1px solid #1a1a1a;border-radius:8px;padding:32px 36px;margin-bottom:35px} .manifesto-lede{color:#c9a868;font-family:Georgia,serif;font-size:1.4rem;font-style:italic;line-height:1.5;margin-bottom:18px;font-weight:400} .manifesto-preamble p{color:#c0c0c0;font-size:0.95rem;line-height:1.75;margin-bottom:14px} .manifesto-preamble p:last-child{margin-bottom:0} .manifesto-title{color:#c9a868;border-bottom-color:#2a2015} .manifesto-list{list-style:none;counter-reset:none;padding:0;margin:0 0 50px;display:grid;gap:18px} .manifesto-point{background:linear-gradient(135deg,#0a0a0a 0%,#0d0d0d 100%);border:1px solid #1a1a1a;border-left:3px solid #4a3d2b;border-radius:8px;padding:28px 32px 26px;position:relative;transition:border-left-color 0.4s,background 0.4s} .manifesto-point:hover{border-left-color:#c9a868;background:linear-gradient(135deg,#0d0a08 0%,#100d0a 100%)} .manifesto-point .point-num{position:absolute;top:18px;right:24px;font-family:Georgia,serif;font-size:1.6rem;color:#2a2015;letter-spacing:2px;transition:color 0.4s} .manifesto-point:hover .point-num{color:#6b5535} .manifesto-point h3{color:#c9a868;font-size:1.05rem;font-weight:400;letter-spacing:1px;margin-bottom:12px;padding-right:60px} .manifesto-point p{color:#b8b8b8;font-size:0.92rem;line-height:1.75} .manifesto-closing{background:linear-gradient(135deg,#0d0a08 0%,#100d0a 100%);border:1px solid #2a2015;border-radius:8px;padding:32px 36px;margin-bottom:45px} .manifesto-closing p{color:#c0c0c0;font-size:0.95rem;line-height:1.75;margin-bottom:14px} .manifesto-closing p:last-child{margin-bottom:0} .closing-call{color:#c9a868 !important;font-family:Georgia,serif;font-style:italic;font-size:1.05rem !important} .sign-section{background:linear-gradient(135deg,#0a0a0a 0%,#0d0d0d 100%);border:1px solid #2a2015;border-radius:10px;padding:40px 36px;margin-bottom:35px} .sign-header{text-align:center;margin-bottom:30px} .sign-header h2{color:#c9a868;font-size:1.3rem;font-weight:300;letter-spacing:2px;text-transform:uppercase;margin-bottom:10px} .sign-subtitle{color:#909090;font-size:0.85rem;font-style:italic} .sign-counter{text-align:center;padding:24px 20px;margin-bottom:32px;background:rgba(0,0,0,0.3);border:1px solid #2a2015;border-radius:8px} .counter-num{font-size:3.2rem;font-weight:200;color:#c9a868;font-family:'Courier New',monospace;line-height:1} .counter-label{color:#909090;font-size:0.75rem;text-transform:uppercase;letter-spacing:2px;margin-top:8px} .sign-form{display:grid;gap:18px} .form-row label{display:block} .form-label{display:block;color:#b0b0b0;font-size:0.78rem;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px} .form-label em{text-transform:none;letter-spacing:0;color:#707070;font-style:normal;font-size:0.78rem;margin-left:8px} .sign-form input[type="text"],.sign-form input[type="email"],.sign-form textarea{width:100%;background:#050505;border:1px solid #2a2015;color:#e0e0e0;padding:12px 14px;border-radius:6px;font-family:inherit;font-size:0.95rem;transition:border-color 0.3s,background 0.3s} .sign-form input:focus,.sign-form textarea:focus{outline:none;border-color:#c9a868;background:#0a0807} .sign-form textarea{resize:vertical;min-height:60px} .hp-field{position:absolute;left:-10000px;width:1px;height:1px;overflow:hidden} .privacy-note{background:rgba(0,0,0,0.3);border:1px solid #1a1a1a;border-left:2px solid #4a3d2b;border-radius:6px;padding:14px 18px;margin:6px 0 4px;font-size:0.78rem;color:#909090;line-height:1.65} .privacy-note strong{color:#c9a868;font-weight:400} .privacy-note a{color:#c9a868;text-decoration:none;border-bottom:1px dotted #4a3d2b} .privacy-note a:hover{color:#e0c084;border-bottom-color:#c9a868} .form-actions{display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-top:8px} .sign-form button[type="submit"]{padding:14px 40px;font-size:0.85rem;background:transparent;border:1px solid #c9a868;color:#c9a868;cursor:pointer;letter-spacing:2px;text-transform:uppercase;transition:all 0.3s;border-radius:4px} .sign-form button[type="submit"]:hover:not(:disabled){background:#c9a868;color:#050505} .sign-form button[type="submit"]:disabled{opacity:0.5;cursor:not-allowed} .form-status{font-size:0.85rem;color:#909090} .form-status.status-ok{color:#88bb88} .form-status.status-err{color:#cc7777} .form-status.status-pending{color:#c9a868} .share-section{text-align:center;margin-bottom:35px;padding:32px 30px;background:rgba(0,0,0,0.25);border:1px solid #1a1a1a;border-radius:8px} .share-section h2{color:#c9a868;font-size:1.2rem;font-weight:300;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px} .share-intro{color:#909090;font-size:0.85rem;font-style:italic;margin-bottom:22px} .share-buttons{display:flex;flex-wrap:wrap;gap:10px;justify-content:center} .share-btn{padding:10px 18px;font-size:0.78rem;background:transparent;border:1px solid #2a2015;color:#c9a868;text-decoration:none;cursor:pointer;letter-spacing:1px;text-transform:uppercase;border-radius:4px;transition:all 0.3s;font-family:inherit} .share-btn:hover{background:#c9a868;color:#050505;border-color:#c9a868} .recent-section{margin-bottom:40px;scroll-margin-top:20px} .recent-section h2{color:#909090;font-size:0.9rem;font-weight:300;letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid #1a1a1a} .signatures-counter{text-align:center;color:#909090;font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:22px} .recent-list.is-loading{opacity:0.45;transition:opacity 0.2s} .pagination{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;align-items:center;margin-top:28px} .pagination:empty{display:none} .pg-btn{background:transparent;border:1px solid #2a2015;color:#c9a868;padding:8px 14px;font-size:0.78rem;cursor:pointer;border-radius:4px;font-family:inherit;letter-spacing:0.5px;transition:background 0.25s,color 0.25s,border-color 0.25s;min-width:38px;line-height:1} .pg-btn:hover:not(:disabled):not(.is-active){background:rgba(201,168,104,0.12);border-color:#c9a868;color:#e0c084} .pg-btn:disabled{opacity:0.3;cursor:not-allowed} .pg-btn.is-active{background:#c9a868;color:#050505;border-color:#c9a868;cursor:default} .pg-gap{color:#707070;padding:0 4px;font-size:0.85rem} .recent-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px} .recent-empty{grid-column:1 / -1;color:#707070;font-style:italic;font-size:0.85rem;text-align:center;padding:20px} .recent-item{background:#080808;border:1px solid #1a1a1a;border-left:2px solid #4a3d2b;border-radius:6px;padding:14px 16px} .recent-name{color:#d0d0d0;font-size:0.9rem;margin-bottom:4px} .recent-meta{color:#707070;font-size:0.7rem;text-transform:uppercase;letter-spacing:1px} .recent-comment{color:#a0a0a0;font-size:0.82rem;margin-top:8px;padding-top:8px;border-top:1px dashed #1a1a1a;line-height:1.55;font-style:italic} @media (max-width:768px){h1{font-size:1.8rem} .year-display{font-size:2rem} .stats-row{grid-template-columns:repeat(2,1fr)} .perspective-box{grid-template-columns:1fr} .perspective-value{font-size:1.6rem} .display-row{gap:20px} .info-grid{grid-template-columns:1fr} .question-mark{font-size:5rem;right:5%} .chart-container{height:350px} .ref-grid{grid-template-columns:1fr} .manifesto-teaser{padding:22px 20px} .manifesto-preamble,.manifesto-closing,.sign-section{padding:26px 22px} .manifesto-point{padding:22px 22px 20px} .manifesto-point h3{padding-right:48px} .manifesto-point .point-num{font-size:1.3rem;top:16px;right:18px} .counter-num{font-size:2.4rem} .recent-list{grid-template-columns:1fr} }